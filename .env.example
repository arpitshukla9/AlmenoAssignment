# Copy this file to .env before running docker compose up.
# Defaults below use the mock LLM provider so the system runs end-to-end
# with zero spend and no API key. Switch to "gemini" + add a real key
# to use the live LLM.

LLM_PROVIDER=mock
GEMINI_API_KEY=
LLM_MODEL=gemini-1.5-flash
LLM_BATCH_SIZE=20
LLM_MAX_RETRIES=3
LLM_BACKOFF_BASE_SECONDS=2.0
