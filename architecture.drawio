<mxfile host="app.diagrams.net">
  <diagram name="AI Transaction Pipeline HLD">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1000">
      <root>

        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->

        <mxCell id="title"
          value="AI-Powered Transaction Processing Pipeline&#10;High Level Architecture (HLD)"
          style="text;html=1;fontSize=24;fontStyle=1;"
          parent="1"
          vertex="1">
          <mxGeometry x="430" y="20" width="700" height="60" as="geometry"/>
        </mxCell>

        <!-- Docker Boundary -->

        <mxCell id="docker"
          value="Docker Compose Network"
          style="rounded=1;whiteSpace=wrap;html=1;dashed=1;strokeWidth=2;"
          parent="1"
          vertex="1">
          <mxGeometry x="50" y="100" width="1450" height="800" as="geometry"/>
        </mxCell>

        <!-- Client -->

        <mxCell id="client"
          value="Client&#10;(Browser / curl)"
          style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;html=1;"
          parent="1"
          vertex="1">
          <mxGeometry x="120" y="180" width="180" height="80" as="geometry"/>
        </mxCell>

        <!-- FastAPI -->

        <mxCell id="api"
          value="FastAPI API&#10;&#10;POST /jobs/upload&#10;GET /status&#10;GET /results&#10;GET /jobs"
          style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;html=1;"
          parent="1"
          vertex="1">
          <mxGeometry x="450" y="150" width="250" height="150" as="geometry"/>
        </mxCell>

        <!-- PostgreSQL -->

        <mxCell id="db"
          value="PostgreSQL&#10;&#10;Jobs&#10;Transactions&#10;JobSummary"
          style="shape=cylinder3;fillColor=#d5e8d4;strokeColor=#82b366;html=1;"
          parent="1"
          vertex="1">
          <mxGeometry x="430" y="520" width="250" height="120" as="geometry"/>
        </mxCell>

        <!-- Redis -->

        <mxCell id="redis"
          value="Redis Queue"
          style="rounded=1;fillColor=#f8cecc;strokeColor=#b85450;html=1;"
          parent="1"
          vertex="1">
          <mxGeometry x="850" y="180" width="180" height="80" as="geometry"/>
        </mxCell>

        <!-- Worker -->

        <mxCell id="worker"
          value="RQ Worker"
          style="rounded=1;fillColor=#ffe6cc;strokeColor=#d79b00;html=1;"
          parent="1"
          vertex="1">
          <mxGeometry x="850" y="350" width="180" height="80" as="geometry"/>
        </mxCell>

        <!-- Pipeline -->

        <mxCell id="pipeline"
          value="Transaction Processing Pipeline&#10;&#10;1. Data Cleaning&#10;2. Anomaly Detection&#10;3. LLM Classification&#10;4. LLM Narrative&#10;5. Retry &amp; Backoff"
          style="rounded=1;fillColor=#ffe6cc;strokeColor=#d79b00;html=1;"
          parent="1"
          vertex="1">
          <mxGeometry x="1100" y="280" width="300" height="250" as="geometry"/>
        </mxCell>

        <!-- LLM -->

        <mxCell id="llm"
          value="Gemini 1.5 Flash&#10;(or Mock Provider)"
          style="rounded=1;fillColor=#e1d5e7;strokeColor=#9673a6;html=1;"
          parent="1"
          vertex="1">
          <mxGeometry x="1150" y="620" width="220" height="100" as="geometry"/>
        </mxCell>

        <!-- Edges -->

        <mxCell id="e1" edge="1" parent="1" source="client" target="api">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e2" edge="1" parent="1" source="api" target="db">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e3" edge="1" parent="1" source="api" target="redis">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e4" edge="1" parent="1" source="redis" target="worker">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e5" edge="1" parent="1" source="worker" target="pipeline">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e6" edge="1" parent="1" source="pipeline" target="llm">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e7" edge="1" parent="1" source="pipeline" target="db">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
